HOST=127.0.0.1
PORT=3001
ALLOWED_ORIGINS=https://biasbreaker-career.netlify.app,http://localhost:3000
MAX_CONCURRENT_JOBS=2

DEFAULT_LLM_PROVIDER=mimo
DEFAULT_LLM_MODEL=mimo-v2.5-pro
MIMO_API_KEY=replace-with-your-key
MIMO_BASE_URL=https://replace-with-mimo-api-base-url
MODEL_TIMEOUT_SECONDS=90

DEFAULT_EMBEDDING_PROVIDER=hunyuan
DEFAULT_EMBEDDING_MODEL=hunyuan-embedding
HUNYUAN_API_KEY=replace-with-your-key
HUNYUAN_BASE_URL=https://replace-with-hunyuan-api-base-url
EMBEDDING_TIMEOUT_SECONDS=8
